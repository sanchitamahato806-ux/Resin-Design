// Render Gallery
const galleryGrid = document.getElementById('gallery-grid');
galleryData.forEach(category => {
  const catTitle = document.createElement('h3');
  catTitle.textContent = category.category;
  catTitle.style.gridColumn = '1 / -1';
  catTitle.style.margin = '1rem 0';
  galleryGrid.appendChild(catTitle);

  category.items.forEach(item => {
    const div = document.createElement('div');
    div.classList.add('gallery-item');
    div.innerHTML = `
      <img src="${item.img}" alt="${item.name}">
      <div class="info">
        <p>${item.name}</p>
        <p>₹${item.price}</p>
        <a href="https://wa.me/1234567890?text=Hi!%20I%20want%20to%20buy%20${encodeURIComponent(item.name)}%20for%20₹${item.price}" target="_blank" class="btn">Buy Now</a>
      </div>
    `;
    galleryGrid.appendChild(div);
  });
});
