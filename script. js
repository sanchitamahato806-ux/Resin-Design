  {
    category: 'Photo Frames',
    items: [
      {name: 'Photo Frame 1', img: 'images/img2.jpg', price: 1500},
      {name: 'Photo Frame 2', img: 'images/img4.jpg', price: 1800},
      {name: 'Photo Frame 3', img: 'images/img8.jpg', price: 2000},
      {name: 'Photo Frame 4', img: 'images/img9.jpg', price: 2200},
    ]
  },
  {
    category: 'Jewelry',
    items: [
