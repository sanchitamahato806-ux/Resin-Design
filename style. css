:root {
  --primary: #fdf6f0;        /* Soft off-white background */
  --secondary: #f8f0e3;      /* Slightly darker sections / cards */
  --accent: #c49f35;         /* Warm, muted gold for buttons & highlights */
  --accent-hover: #b0882e;   /* Slightly darker gold for hover */
  --text: #3b2f2f;           /* Warm dark brown for readable text */
  --text-light: #6b5e5e;     /* Secondary text color */
  --glass: rgba(255,255,255,0.1); /* Subtle glass effect */
  --glass-border: rgba(196,159,53,0.2);
  --shadow: rgba(0,0,0,0.05);  /* Soft shadow for cards */
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  font-family: 'Poppins', sans-serif;
  background: var(--primary);
  color: var(--text);
  line-height: 1.6;
}

/* Header */
.header {
  position: fixed;
  top: 0;
  width: 100%;
  background: var(--primary);
  border-bottom: 1px solid var(--glass-border);
  z-index: 1000;
}

.nav {
  max-width: 1400px;
  margin: auto;
  padding: 1rem 2rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.logo-premium {
  font-family: 'Playfair Display', serif;
  font-weight: 700;
  font-size: 2rem;
  color: var(--text);
  text-decoration: none;
}

.nav-menu {
  display: flex;
  list-style: none;
  gap: 2rem;
}

.nav-link {
  color: var(--text);
  text-decoration: none;
  font-weight: 500;
  transition: 0.3s ease;
}

.nav-link:hover { color: var(--accent); }

.hamburger { 
  display: none; 
  cursor: pointer; 
  flex-direction: column; 
  gap: 5px; 
}

.hamburger span { 
  width: 28px; 
  height: 3px; 
  background: var(--accent); 
  border-radius: 2px; 
}

/* Hero */
.hero {
  background: linear-gradient(to bottom, var(--primary), var(--secondary));
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding-top: 80px;
}

.hero-title { 
  font-family: 'Playfair Display', serif; 
  font-size: 4rem; 
  color: var(--text); 
  margin-bottom: 1rem; 
}

.hero-desc { 
  font-size: 1.2rem; 
  margin-bottom: 2rem; 
  color: var(--text-light);
}

.cta-btn {
  background: var(--accent);
  color: #fff;
  padding: 1rem 2rem;
  border-radius: 50px;
  text-decoration: none;
  font-weight: 600;
  transition: 0.3s ease;
}

.cta-btn:hover { background: var(--accent-hover); }

/* Gallery */
.section-title { 
  text-align: center; 
  font-family: 'Playfair Display', serif; 
  font-size: 2.5rem; 
  margin-bottom: 3rem; 
  color: var(--text);
}

.gallery-grid { 
  display: grid; 
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); 
  gap: 2rem; 
  max-width: 1200px; 
  margin: auto;
}

.gallery-item { 
  position: relative; 
  overflow: hidden; 
  border-radius: 15px; 
  cursor: pointer; 
  background: var(--secondary);
  box-shadow: 0 6px 15px var(--shadow);
  transition: transform 0.4s ease, box-shadow 0.4s ease;
}

.gallery-item:hover { 
  transform: translateY(-5px) scale(1.02); 
  box-shadow: 0 10px 20px var(--shadow);
}

.gallery-item img { 
  width: 100%; 
  height: 300px; 
  object-fit: cover; 
  transition: transform 0.4s ease; 
}

.gallery-item:hover img { transform: scale(1.1); }

.gallery-item .info { 
  position: absolute; 
  bottom: 0; 
  width: 100%; 
  background: rgba(255,255,255,0.85); 
  text-align: center; 
  padding: 0.5rem 0; 
  font-weight: 500;
  color: var(--text);
}

/* Order Form */
.order-form { 
  max-width: 600px; 
  margin: auto; 
  display: flex; 
  flex-direction: column; 
  gap: 1rem; 
  padding: 2rem;
  background: var(--secondary);
  border-radius: 15px;
  box-shadow: 0 6px 15px var(--shadow);
}

.order-form input, 
.order-form select,
.order-form button { 
  padding: 0.8rem 1rem; 
  border-radius: 10px; 
  border: 1px solid #e0d4c2; 
  background: #fff8f3;
  color: var(--text);
  font-size: 1rem;
}

.order-form button { 
  background: var(--accent); 
  color: #fff; 
  font-weight: 600; 
  cursor: pointer; 
  transition: 0.3s ease; 
}

.order-form button:hover { background: var(--accent-hover); }

/* WhatsApp Button */
.whatsapp-btn { 
  position: fixed; 
  bottom: 40px; 
  right: 40px; 
  width: 60px; 
  height: 60px; 
  border-radius: 50%; 
  background: #25d366; 
  display: flex; 
  align-items: center; 
  justify-content: center; 
  color: white; 
  font-size: 1.8rem; 
  box-shadow: 0 5px 15px rgba(0,0,0,0.2);
  transition: transform 0.3s ease;
}

.whatsapp-btn:hover { transform: scale(1.1); }

/* Responsive */
@media screen and (max-width: 768px) {
  .nav-menu { display: none; }
  .hamburger { display: flex; }
}
