<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Resin Art Gallery</title>
  <link rel="stylesheet" href="css/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
</head>
<body>

  <!-- Header -->
  <header class="header">
    <nav class="nav">
      <a href="#" class="logo-premium">ResinGallery</a>
      <ul class="nav-menu">
        <li><a href="#hero" class="nav-link">Home</a></li>
        <li><a href="#photo-frame" class="nav-link">Photo Frames</a></li>
        <li><a href="#jewelry" class="nav-link">Jewelry</a></li>
        <li><a href="#scenery" class="nav-link">Scenery</a></li>
        <li><a href="#order" class="nav-link">Order</a></li>
      </ul>
    </nav>
  </header>

  <!-- Hero -->
  <section class="hero" id="hero">
    <div>
      <h1 class="hero-title">Resin Art Collections</h1>
      <p class="hero-desc">Unique handcrafted resin artworks: Photo Frames, Jewelry, Scenery and more!</p>
      <a href="#order" class="cta-btn">Order Now</a>
    </div>
  </section>

  <!-- Photo Frames Gallery -->
  <section id="photo-frame">
    <h2 class="section-title">Photo Frames</h2>
    <div class="gallery-grid">
      <div class="gallery-item">
        <img src="images/img2.jpg" alt="Photo Frame 1">
        <div class="info">Photo Frame 1</div>
      </div>
      <div class="gallery-item">
        <img src="images/img4.jpg" alt="Photo Frame 2">
        <div class="info">Photo Frame 2</div>
      </div>
      <div class="gallery-item">
        <img src="images/img8.jpg" alt="Photo Frame 3">
        <div class="info">Photo Frame 3</div>
      </div>
      <div class="gallery-item">
        <img src="images/img9.jpg" alt="Photo Frame 4">
        <div class="info">Photo Frame 4</div>
      </div>
    </div>
  </section>

  <!-- Jewelry Gallery -->
  <section id="jewelry">
    <h2 class="section-title">Jewelry</h2>
    <div class="gallery-grid">
      <div class="gallery-item">
        <img src="images/img3.jpg" alt="Jewelry 1">
        <div class="info">Jewelry 1</div>
      </div>
    </div>
  </section>

  <!-- Scenery Gallery -->
  <section id="scenery">
    <h2 class="section-title">Scenery Frames</h2>
    <div class="gallery-grid">
      <div class="gallery-item">
        <img src="images/img1.jpg" alt="Scenery 1">
        <div class="info">Scenery 1</div>
      </div>
      <div class="gallery-item">
        <img src="images/img5.jpg" alt="Scenery 2">
        <div class="info">Scenery 2</div>
      </div>
      <div class="gallery-item">
        <img src="images/img6.jpg" alt="Scenery 3">
        <div class="info">Scenery 3</div>
      </div>
      <div class="gallery-item">
        <img src="images/img7.jpg" alt="Scenery 4">
        <div class="info">Scenery 4</div>
      </div>
      <div class="gallery-item">
        <img src="images/img11.jpg" alt="Scenery 5">
        <div class="info">Scenery 5</div>
      </div>
    </div>
  </section>

  <!-- Order Form -->
  <section id="order">
    <h2 class="section-title">Place Your Order</h2>
    <form class="order-form" id="orderForm">
      <input type="text" placeholder="Your Name" id="name" required>
      <input type="email" placeholder="Your Email" id="email" required>
      <input type="text" placeholder="Item Name" id="item" required>
      <input type="number" placeholder="Quantity" id="quantity" required>
      <button type="submit" class="btn-large">Send Order via WhatsApp</button>
    </form>
  </section>

  <!-- WhatsApp Floating Button -->
  <a href="https://wa.me/91XXXXXXXXXX" target="_blank" class="whatsapp-btn">📱</a>

  <script src="js/script.js"></script>
</body>
</html>
