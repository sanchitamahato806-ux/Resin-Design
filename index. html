<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Resin Dreams - Luxury Handcrafted Resin Art</title>
<link rel="stylesheet" href="style.css">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Playfair+Display:wght@400;700;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
<!-- Header -->
<header class="header">
  <nav class="nav">
    <div class="nav-logo">
      <a href="#home" class="logo-premium">Resin Dreams</a>
    </div>
    <ul class="nav-menu">
      <li><a href="#home" class="nav-link">Home</a></li>
      <li><a href="#gallery" class="nav-link">Gallery</a></li>
      <li><a href="#order" class="nav-link">Order</a></li>
    </ul>
    <div class="hamburger">
      <span></span>
      <span></span>
      <span></span>
    </div>
  </nav>
</header>

<!-- Hero Section -->
<section id="home" class="hero">
  <div class="hero-container">
    <div class="hero-content fade-in-up">
      <h1 class="hero-title">Luxury Resin Art</h1>
      <p class="hero-desc">Handcrafted masterpieces blending artistry with elegance</p>
      <a href="#gallery" class="cta-btn"><i class="fas fa-gem"></i> Explore Gallery</a>
    </div>
  </div>
</section>

<!-- Gallery Section -->
<section id="gallery" class="section gallery">
  <h2 class="section-title">Our Collections</h2>
  <div class="gallery-grid" id="gallery-grid">
    <!-- Gallery items inserted via JS -->
  </div>
</section>

<!-- Order Section -->
<section id="order" class="section">
  <h2 class="section-title">Place Your Order</h2>
  <form id="orderForm" class="order-form">
    <input type="text" name="name" placeholder="Your Name" required>
    <input type="email" name="email" placeholder="Your Email" required>
    <input type="text" name="idea" placeholder="Your Idea / Product Name" required>
    <input type="number" name="budget" placeholder="Your Budget (₹)" required>
    <button type="submit" class="btn-large">Send Order via WhatsApp</button>
  </form>
</section>

<!-- WhatsApp Button -->
<a href="https://wa.me/1234567890" class="whatsapp-btn" target="_blank"><i class="fab fa-whatsapp"></i></a>

<script src="script.js"></script>
</body>
</html>
